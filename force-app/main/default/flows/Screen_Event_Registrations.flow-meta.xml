    <description>Displays a table of Registration records for an Event, showing capacity percentage and total cost summary.</description>
    <formulas>
        <name>frml_CapacityPercentage</name>
        <dataType>Number</dataType>
        <expression>IF(OR(ISBLANK({!rec_Event.Capacity__c}), {!rec_Event.Capacity__c} = 0), 0, ({!rec_Event.Total_Registrations__c} / {!rec_Event.Capacity__c}) * 100)</expression>
        <scale>1</scale>
    </formulas>
    <interviewLabel>Screen_Event_Registrations {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Event Registrations</label>
