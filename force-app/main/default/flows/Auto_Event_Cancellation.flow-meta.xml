            <value>
                <stringValue>Cancelled</stringValue>
            </value>
        </inputAssignments>
        <object>Registration__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Sponsorships_To_Cancelled</name>
        <label>Update Sponsorships To Cancelled</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
